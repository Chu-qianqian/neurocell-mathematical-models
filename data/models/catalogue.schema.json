{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Neurocell equation-aware model catalogue record",
  "type": "object",
  "required": ["model_id", "model_name", "cell_type", "biological_process", "formalism", "scale", "primary_source_doi", "persistent_url", "bibliography_status", "equation_status", "implementation_status", "license_status", "equation_page", "equation_source_locator", "equation_verification_source", "equation_transcription_type", "variable_registry_status", "parameter_registry_status", "initial_conditions_status", "boundary_conditions_status", "numerical_method_status", "model_scope", "full_text_access_status", "code_license_status", "last_verified", "curation_note"],
  "properties": {
    "model_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_-]*$"},
    "model_name": {"type": "string", "minLength": 1},
    "cell_type": {"type": "string", "minLength": 1},
    "biological_process": {"type": "string", "minLength": 1},
    "formalism": {"enum": ["ODE", "PDE", "hybrid_ODE", "hybrid_ODE_PDE", "stochastic", "agent_based", "compartmental", "other"]},
    "scale": {"enum": ["molecular", "single_cell", "population", "tissue", "network", "multi_scale"]},
    "primary_source_doi": {"type": "string", "pattern": "^10\\.[^\\s/]+/.+"},
    "persistent_url": {"type": "string", "pattern": "^https://doi.org/10\\."},
    "bibliography_status": {"enum": ["verified_bibliography", "candidate", "needs_review"]},
    "equation_status": {"enum": ["not_verified", "bibliography_verified", "equation_located", "equation_transcribed", "independently_checked", "parameters_incomplete", "full_text_unavailable", "license_unclear"]},
    "implementation_status": {"enum": ["not_imported", "source_linked", "reproduced", "validated"]},
    "license_status": {"enum": ["not_assessed", "license_unclear", "documented", "compatible_for_inclusion"]},
    "equation_page": {"type": "string", "minLength": 1},
    "equation_source_locator": {"type": "string", "minLength": 1},
    "equation_verification_source": {"type": "string", "minLength": 1},
    "equation_transcription_type": {"enum": ["not_applicable", "exact_verified_transcription", "equivalent_notation_with_mapping", "conceptual_schematic"]},
    "variable_registry_status": {"enum": ["not_verified", "registered"]},
    "parameter_registry_status": {"enum": ["not_verified", "registered", "parameters_incomplete"]},
    "initial_conditions_status": {"enum": ["not_verified", "source_example_located", "registered"]},
    "boundary_conditions_status": {"enum": ["not_verified", "not_applicable", "registered"]},
    "numerical_method_status": {"enum": ["not_verified", "source_example_located", "registered"]},
    "model_scope": {"enum": ["cell_intrinsic", "cell_function", "cell_population", "coupled_multicellular", "indirect_parameterization"]},
    "full_text_access_status": {"enum": ["not_verified", "source_identified", "source_inspected", "full_text_unavailable"]},
    "code_license_status": {"enum": ["not_assessed", "license_unclear", "documented", "compatible_for_inclusion"]},
    "last_verified": {"type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$"},
    "curation_note": {"type": "string", "minLength": 1}
  },
  "additionalProperties": false
}

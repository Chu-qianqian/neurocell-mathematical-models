{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Neurocell mathematical model catalogue record",
  "description": "Schema for models/model_catalog.csv, the sole hand-maintained model catalogue.",
  "type": "object",
  "required": [
    "model_id",
    "model_name",
    "cell_type",
    "cell_subtype",
    "biological_function",
    "mathematical_form",
    "spatial_model",
    "stochastic",
    "scale",
    "state_variables",
    "main_parameters",
    "input",
    "output",
    "original_paper_title",
    "original_paper_authors",
    "publication_year",
    "journal",
    "doi",
    "pmid",
    "paper_url",
    "open_access_status",
    "code_available",
    "code_url",
    "code_license",
    "model_database",
    "model_database_url",
    "experimental_validation",
    "implementation_status",
    "recommended_platform",
    "quality_tier",
    "model_scope",
    "biological_cell_scope",
    "nervous_system_region",
    "model_scale",
    "interaction_scope",
    "network_type",
    "spatial_structure",
    "stochasticity",
    "plasticity_scope",
    "parent_model_id",
    "related_model_ids",
    "network_conditions_status",
    "network_conditions_locator",
    "event_handling_status",
    "event_handling_locator",
    "evidence_notes",
    "limitations",
    "equation_page",
    "equation_status",
    "equation_source_locator",
    "equation_verification_source",
    "equation_transcription_type",
    "variable_registry_status",
    "parameter_registry_status",
    "initial_conditions_status",
    "boundary_conditions_status",
    "numerical_method_status",
    "full_text_access_status",
    "code_license_status",
    "last_verified",
    "brian2_compatibility",
    "brian2_compatibility_reason",
    "brian2_implementation_status",
    "brian2_version",
    "implementation_scope",
    "numerical_test_status",
    "reference_behavior_status",
    "reproduction_status"
  ],
  "properties": {
    "model_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]*$"
    },
    "model_name": {
      "type": "string"
    },
    "cell_type": {
      "type": "string",
      "enum": [
        "neuron",
        "synapse",
        "astrocyte",
        "microglia",
        "oligodendrocyte",
        "neural_population",
        "mixed_neuron_astrocyte_system",
        "myelinated_axon",
        "astrocyte_extracellular_system",
        "astrocyte_relevant_calcium_mechanism",
        "excitable_membrane"
      ]
    },
    "cell_subtype": {
      "type": "string"
    },
    "biological_function": {
      "type": "string"
    },
    "mathematical_form": {
      "type": "string",
      "enum": [
        "ordinary_differential_equation",
        "partial_differential_equation",
        "stochastic_differential_equation",
        "difference_equation",
        "event_driven",
        "agent_based",
        "probabilistic",
        "hybrid",
        "other",
        "not_assessed"
      ]
    },
    "spatial_model": {
      "type": "string"
    },
    "stochastic": {
      "type": "string"
    },
    "scale": {
      "type": "string"
    },
    "state_variables": {
      "type": "string"
    },
    "main_parameters": {
      "type": "string"
    },
    "input": {
      "type": "string"
    },
    "output": {
      "type": "string"
    },
    "original_paper_title": {
      "type": "string"
    },
    "original_paper_authors": {
      "type": "string"
    },
    "publication_year": {
      "type": "string"
    },
    "journal": {
      "type": "string"
    },
    "doi": {
      "type": "string",
      "pattern": "^10\\.[^\\s/]+/.+"
    },
    "pmid": {
      "type": "string"
    },
    "paper_url": {
      "type": "string",
      "pattern": "^https://doi\\.org/10\\."
    },
    "open_access_status": {
      "type": "string"
    },
    "code_available": {
      "type": "string"
    },
    "code_url": {
      "type": "string"
    },
    "code_license": {
      "type": "string"
    },
    "model_database": {
      "type": "string"
    },
    "model_database_url": {
      "type": "string"
    },
    "experimental_validation": {
      "type": "string"
    },
    "implementation_status": {
      "type": "string",
      "enum": [
        "not_implemented",
        "planned",
        "syntax_checked",
        "smoke_tested",
        "reference_behavior_reproduced"
      ]
    },
    "recommended_platform": {
      "type": "string"
    },
    "quality_tier": {
      "type": "string",
      "enum": [
        "A",
        "B",
        "C",
        "D"
      ]
    },
    "model_scope": {
      "type": "string",
      "enum": [
        "cell_intrinsic",
        "cell_function",
        "cell_population",
        "coupled_multicellular",
        "indirect_parameterization"
      ]
    },
    "biological_cell_scope": {
      "type": "string",
      "enum": [
        "neuronal",
        "glial",
        "mixed_neuron_glia",
        "neural_population",
        "synaptic",
        "other_nervous_system_related"
      ]
    },
    "nervous_system_region": {
      "type": "string",
      "enum": [
        "not_assessed",
        "central_nervous_system_unspecified",
        "peripheral_nervous_system",
        "cerebral_cortex",
        "hippocampus",
        "hippocampal_ca3_ca1"
      ]
    },
    "model_scale": {
      "type": "string",
      "enum": [
        "molecular",
        "subcellular",
        "single_cell",
        "multicompartment_cell",
        "cell_pair",
        "local_microcircuit",
        "population",
        "neural_mass",
        "neural_field",
        "large_scale_network",
        "whole_brain",
        "not_assessed"
      ]
    },
    "interaction_scope": {
      "type": "string",
      "enum": [
        "none",
        "intrinsic",
        "external_input",
        "synaptic",
        "population_coupling",
        "network_connectivity",
        "neuron_astrocyte",
        "astrocyte_extracellular",
        "not_assessed"
      ]
    },
    "network_type": {
      "type": "string",
      "enum": [
        "not_applicable",
        "spiking_network",
        "firing_rate_network",
        "neural_mass",
        "attractor_network",
        "cortical_microcircuit",
        "interneuron_network",
        "neuron_astrocyte_network",
        "not_assessed"
      ]
    },
    "spatial_structure": {
      "type": "string",
      "enum": [
        "nonspatial",
        "one_dimensional",
        "multicompartment",
        "network_topology",
        "not_assessed"
      ]
    },
    "stochasticity": {
      "type": "string",
      "enum": [
        "deterministic",
        "stochastic",
        "mixed",
        "not_assessed"
      ]
    },
    "plasticity_scope": {
      "type": "string",
      "enum": [
        "none",
        "short_term_synaptic",
        "long_term_synaptic",
        "intrinsic",
        "myelin",
        "network",
        "not_assessed"
      ]
    },
    "parent_model_id": {
      "type": "string"
    },
    "related_model_ids": {
      "type": "string"
    },
    "network_conditions_status": {
      "type": "string",
      "enum": [
        "not_verified",
        "not_applicable",
        "source_identified",
        "source_located",
        "registered"
      ]
    },
    "network_conditions_locator": {
      "type": "string"
    },
    "event_handling_status": {
      "type": "string",
      "enum": [
        "not_verified",
        "not_applicable",
        "source_identified",
        "source_located",
        "registered"
      ]
    },
    "event_handling_locator": {
      "type": "string"
    },
    "evidence_notes": {
      "type": "string"
    },
    "limitations": {
      "type": "string"
    },
    "equation_page": {
      "type": "string"
    },
    "equation_status": {
      "type": "string",
      "enum": [
        "bibliography_verified",
        "equation_located",
        "equation_transcribed",
        "second_pass_checked",
        "independently_checked",
        "parameters_incomplete",
        "full_text_unavailable",
        "license_unclear",
        "not_verified"
      ]
    },
    "equation_source_locator": {
      "type": "string"
    },
    "equation_verification_source": {
      "type": "string"
    },
    "equation_transcription_type": {
      "type": "string",
      "enum": [
        "not_applicable",
        "exact_verified_transcription",
        "equivalent_notation_with_mapping",
        "conceptual_schematic_not_source_verified"
      ]
    },
    "variable_registry_status": {
      "type": "string",
      "enum": [
        "not_verified",
        "registered"
      ]
    },
    "parameter_registry_status": {
      "type": "string",
      "enum": [
        "not_verified",
        "registered",
        "parameters_incomplete"
      ]
    },
    "initial_conditions_status": {
      "type": "string",
      "enum": [
        "not_verified",
        "not_applicable",
        "source_example_located",
        "registered"
      ]
    },
    "boundary_conditions_status": {
      "type": "string",
      "enum": [
        "not_verified",
        "not_applicable",
        "source_example_located",
        "registered"
      ]
    },
    "numerical_method_status": {
      "type": "string",
      "enum": [
        "not_verified",
        "not_applicable",
        "source_example_located",
        "registered"
      ]
    },
    "full_text_access_status": {
      "type": "string",
      "enum": [
        "not_verified",
        "source_identified",
        "source_inspected",
        "full_text_unavailable"
      ]
    },
    "code_license_status": {
      "type": "string",
      "enum": [
        "not_assessed",
        "license_unclear",
        "documented",
        "compatible_for_inclusion"
      ]
    },
    "last_verified": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "brian2_compatibility": {
      "type": "string",
      "enum": [
        "native",
        "possible_custom_ode",
        "possible_network_implementation",
        "difficult_or_out_of_scope",
        "not_assessed"
      ]
    },
    "brian2_compatibility_reason": {
      "type": "string"
    },
    "brian2_implementation_status": {
      "type": "string",
      "enum": [
        "not_implemented",
        "planned",
        "syntax_checked",
        "smoke_tested",
        "reference_behavior_reproduced"
      ]
    },
    "brian2_version": {
      "type": "string"
    },
    "implementation_scope": {
      "type": "string"
    },
    "numerical_test_status": {
      "type": "string",
      "enum": [
        "not_run",
        "passed",
        "failed",
        "not_applicable"
      ]
    },
    "reference_behavior_status": {
      "type": "string",
      "enum": [
        "not_assessed",
        "not_reproduced",
        "qualitative_match",
        "reproduced"
      ]
    },
    "reproduction_status": {
      "type": "string",
      "enum": [
        "not_attempted",
        "implementation_only",
        "qualitative_behavior_reproduced",
        "paper_result_partially_reproduced",
        "paper_result_reproduced"
      ]
    }
  },
  "additionalProperties": false
}
